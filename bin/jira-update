#!/usr/bin/env python3
"""Generate Jira status update for Slack.

Usage:
    jira-update          # print to stdout
    jira-update -c       # copy to clipboard (macOS pbcopy)

Environment variables:
    JIRA_EMAIL       - Your Atlassian email
    JIRA_API_TOKEN   - Your Atlassian API token
    JIRA_URL         - (optional) Jira instance URL, defaults to https://appier.atlassian.net
"""

import json
import os
import subprocess
import sys
import urllib.request
import base64

JIRA_URL = os.environ.get("JIRA_URL", "https://appier.atlassian.net")
JIRA_EMAIL = os.environ.get("JIRA_EMAIL")
JIRA_API_TOKEN = os.environ.get("JIRA_API_TOKEN")

# Custom sort order: further along = listed first
STATUS_ORDER = {
    "done": 0,
    "code complete": 1,
    "in review": 2,
    "qa": 3,
    "in progress": 4,
    "to do": 5,
}


def fetch_issues():
    jql = "assignee = currentUser() AND status NOT IN (Backlog) AND issuetype != Epic ORDER BY updated DESC"
    params = urllib.parse.urlencode({
        "jql": jql,
        "fields": "summary,status",
        "maxResults": "50",
    })
    url = f"{JIRA_URL}/rest/api/3/search/jql?{params}"

    cred = base64.b64encode(f"{JIRA_EMAIL}:{JIRA_API_TOKEN}".encode()).decode()
    req = urllib.request.Request(url, headers={
        "Accept": "application/json",
        "Authorization": f"Basic {cred}",
    })

    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())["issues"]


def format_status(name):
    return name.lower().replace("_", " ")


def sort_key(issue):
    status = format_status(issue["fields"]["status"]["name"])
    return STATUS_ORDER.get(status, 99)


def main():
    if not JIRA_EMAIL or not JIRA_API_TOKEN:
        print("Error: Set JIRA_EMAIL and JIRA_API_TOKEN environment variables", file=sys.stderr)
        print("  export JIRA_EMAIL='you@appier.com'", file=sys.stderr)
        print("  export JIRA_API_TOKEN='your-api-token'", file=sys.stderr)
        sys.exit(1)

    import urllib.parse  # noqa: delayed import for top-level usage
    issues = fetch_issues()
    issues.sort(key=sort_key)

    lines = []
    for issue in issues:
        key = issue["key"]
        summary = issue["fields"]["summary"]
        status = format_status(issue["fields"]["status"]["name"])
        if status == "to do":
            lines.append(f"- (todo) {key} {summary}")
        elif status == "done":
            lines.append(f"- (done) {key} {summary}")
        else:
            lines.append(f"- ({status}) {key} {summary}")
            lines.append(f"  * ")

    code_content = "\n".join(lines)

    print(f"Update:\n{code_content}")
    if "-c" in sys.argv:
        clipboard = f"Update:\n{code_content}"
        subprocess.run(["pbcopy"], input=clipboard.encode(), check=True)
        print("\nCopied to clipboard!", file=sys.stderr)


if __name__ == "__main__":
    main()
